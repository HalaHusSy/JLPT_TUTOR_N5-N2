[{"char":"一","on":"イチ","kun":"ひと(つ)","romaji":"ichi / hito(tsu)","meaning":"หนึ่ง","examples":[{"jp":"一つください。","romaji":"Hitotsu kudasai.","th":"ขอหนึ่งอัน"},{"jp":"一月一日です。","romaji":"Ichi-gatsu tsuitachi desu.","th":"วันที่ 1 มกราคม"},{"jp":"一人で行きます。","romaji":"Hitori de ikimasu.","th":"ไปคนเดียว"}]},{"char":"二","on":"ニ","kun":"ふた(つ)","romaji":"ni / futa(tsu)","meaning":"สอง","examples":[{"jp":"二つあります。","romaji":"Futatsu arimasu.","th":"มีสองอัน"},{"jp":"二月は寒いです。","romaji":"Ni-gatsu wa samui desu.","th":"เดือนกุมภาฯ หนาว"},{"jp":"二人で食べます。","romaji":"Futari de tabemasu.","th":"กินสองคน"}]},{"char":"三","on":"サン","kun":"みっ(つ)","romaji":"san / mi(ttsu)","meaning":"สาม","examples":[{"jp":"三人います。","romaji":"San-nin imasu.","th":"มีสามคน"},{"jp":"三時に会いましょう。","romaji":"San-ji ni aimashou.","th":"เจอกันบ่ายสาม"},{"jp":"三つ目の角を曲がる。","romaji":"Mittsu-me no kado o magaru.","th":"เลี้ยวหัวมุมที่สาม"}]},{"char":"四","on":"シ","kun":"よっ(つ)・よん","romaji":"shi / yon","meaning":"สี่","examples":[{"jp":"四月から学校です。","romaji":"Shi-gatsu kara gakkou desu.","th":"เปิดเทอมเดือนเมษา"},{"jp":"四つ買いました。","romaji":"Yottsu kaimashita.","th":"ซื้อสี่อัน"},{"jp":"四時に終わります。","romaji":"Yo-ji ni owarimasu.","th":"เลิกสี่โมง"}]},{"char":"五","on":"ゴ","kun":"いつ(つ)","romaji":"go / itsu(tsu)","meaning":"ห้า","examples":[{"jp":"五人家族です。","romaji":"Go-nin kazoku desu.","th":"ครอบครัวห้าคน"},{"jp":"五月は休みが多い。","romaji":"Go-gatsu wa yasumi ga ooi.","th":"เดือนพฤษภาฯ วันหยุดเยอะ"},{"jp":"五つください。","romaji":"Itsutsu kudasai.","th":"ขอห้าอัน"}]},{"char":"六","on":"ロク","kun":"むっ(つ)","romaji":"roku / mu(ttsu)","meaning":"หก","examples":[{"jp":"六時に起きます。","romaji":"Roku-ji ni okimasu.","th":"ตื่นหกโมง"},{"jp":"六月は雨の季節です。","romaji":"Roku-gatsu wa ame no kisetsu desu.","th":"เดือนมิถุนาคือฤดูฝน"},{"jp":"六つの問題があります。","romaji":"Muttsu no mondai ga arimasu.","th":"มีหกข้อ"}]},{"char":"七","on":"シチ","kun":"なな(つ)","romaji":"shichi / nana","meaning":"เจ็ด","examples":[{"jp":"七月は暑いです。","romaji":"Shichi-gatsu wa atsui desu.","th":"เดือนกรกฎาฯ ร้อน"},{"jp":"七時の電車。","romaji":"Shichi-ji no densha.","th":"รถไฟเจ็ดโมง"},{"jp":"七つの星。","romaji":"Nanatsu no hoshi.","th":"ดาวเจ็ดดวง"}]},{"char":"八","on":"ハチ","kun":"やっ(つ)","romaji":"hachi / ya(ttsu)","meaning":"แปด","examples":[{"jp":"八時に始まります。","romaji":"Hachi-ji ni hajimarimasu.","th":"เริ่มแปดโมง"},{"jp":"八月は夏休み。","romaji":"Hachi-gatsu wa natsu-yasumi.","th":"สิงหาคมคือปิดเทอม"},{"jp":"八つあります。","romaji":"Yattsu arimasu.","th":"มีแปดอัน"}]},{"char":"九","on":"キュウ・ク","kun":"ここの(つ)","romaji":"kyuu / kokono(tsu)","meaning":"เก้า","examples":[{"jp":"九時に寝ます。","romaji":"Ku-ji ni nemasu.","th":"นอนสามทุ่ม"},{"jp":"九月から秋です。","romaji":"Ku-gatsu kara aki desu.","th":"เดือนกันยาเข้าใบไม้ร่วง"},{"jp":"九つの色。","romaji":"Kokonotsu no iro.","th":"เก้าสี"}]},{"char":"十","on":"ジュウ","kun":"とお","romaji":"juu / too","meaning":"สิบ","examples":[{"jp":"十時です。","romaji":"Juu-ji desu.","th":"สิบโมง"},{"jp":"十月は涼しい。","romaji":"Juu-gatsu wa suzushii.","th":"ตุลาเย็นสบาย"},{"jp":"十日かかります。","romaji":"Tooka kakarimasu.","th":"ใช้เวลาสิบวัน"}]},{"char":"日","on":"ニチ・ジツ","kun":"ひ・か","romaji":"nichi / hi","meaning":"วัน, ดวงอาทิตย์","examples":[{"jp":"日本に住んでいます。","romaji":"Nihon ni sunde imasu.","th":"อยู่ที่ญี่ปุ่น"},{"jp":"今日は良い日です。","romaji":"Kyou wa ii hi desu.","th":"วันนี้เป็นวันที่ดี"},{"jp":"三日後に会いましょう。","romaji":"Mikka go ni aimashou.","th":"เจอกันอีกสามวัน"}]},{"char":"月","on":"ゲツ・ガツ","kun":"つき","romaji":"getsu / tsuki","meaning":"เดือน, พระจันทร์","examples":[{"jp":"月曜日に会議です。","romaji":"Getsuyoubi ni kaigi desu.","th":"ประชุมวันจันทร์"},{"jp":"月がきれいです。","romaji":"Tsuki ga kirei desu.","th":"พระจันทร์สวย"},{"jp":"三月生まれです。","romaji":"San-gatsu umare desu.","th":"เกิดเดือนมีนา"}]},{"char":"火","on":"カ","kun":"ひ","romaji":"ka / hi","meaning":"ไฟ, วันอังคาร","examples":[{"jp":"火曜日休みです。","romaji":"Kayoubi yasumi desu.","th":"วันอังคารหยุด"},{"jp":"火を消してください。","romaji":"Hi o keshite kudasai.","th":"ดับไฟด้วย"},{"jp":"火事に注意。","romaji":"Kaji ni chuui.","th":"ระวังไฟไหม้"}]},{"char":"水","