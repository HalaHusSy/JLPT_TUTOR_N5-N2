[{"char":"時","on":"ジ","kun":"とき","romaji":"ji / toki","meaning":"เวลา, ชั่วโมง","examples":[{"jp":"今何時ですか。","romaji":"Ima nan-ji desu ka.","th":"ตอนนี้กี่โมง"},{"jp":"時間がありません。","romaji":"Jikan ga arimasen.","th":"ไม่มีเวลา"},{"jp":"昔の時代の話です。","romaji":"Mukashi no jidai no hanashi desu.","th":"เป็นเรื่องสมัยโบราณ"}]},{"char":"間","on":"カン","kun":"あいだ","romaji":"kan / aida","meaning":"ระหว่าง, ช่วง","examples":[{"jp":"三日間休みます。","romaji":"Mikka kan yasumimasu.","th":"หยุดสามวัน"},{"jp":"二人の間に座る。","romaji":"Futari no aida ni suwaru.","th":"นั่งระหว่างสองคน"},{"jp":"人間です。","romaji":"Ningen desu.","th":"เป็นมนุษย์"}]},{"char":"分","on":"フン・ブン","kun":"わ(かる)","romaji":"fun / wa(karu)","meaning":"นาที, แบ่ง, เข้าใจ","examples":[{"jp":"十分待ちます。","romaji":"Juppun machimasu.","th":"รอสิบนาที"},{"jp":"意味が分かります。","romaji":"Imi ga wakarimasu.","th":"เข้าใจความหมาย"},{"jp":"三つに分けます。","romaji":"Mittsu ni wakemasu.","th":"แบ่งเป็นสามส่วน"}]},{"char":"好","on":"コウ","kun":"す(き)","romaji":"kou / su(ki)","meaning":"ชอบ, ดี","examples":[{"jp":"猫が好きです。","romaji":"Neko ga suki desu.","th":"ชอบแมว"},{"jp":"好きな食べ物は何ですか。","romaji":"Suki na tabemono wa nan desu ka.","th":"อาหารที่ชอบคืออะไร"},{"jp":"友好関係です。","romaji":"Yuukou kankei desu.","th":"ความสัมพันธ์ฉันมิตร"}]},{"char":"悪","on":"アク","kun":"わる(い)","romaji":"aku / waru(i)","meaning":"ไม่ดี, ชั่ว","examples":[{"jp":"天気が悪いです。","romaji":"Tenki ga warui desu.","th":"อากาศไม่ดี"},{"jp":"悪い人ではない。","romaji":"Warui hito de wa nai.","th":"ไม่ใช่คนเลว"},{"jp":"悪化しています。","romaji":"Akka shite imasu.","th":"กำลังแย่ลง"}]},{"char":"新","on":"シン","kun":"あたら(しい)","romaji":"shin / atara(shii)","meaning":"ใหม่","examples":[{"jp":"新しい車を買いました。","romaji":"Atarashii kuruma o kaimashita.","th":"ซื้อรถใหม่"},{"jp":"新聞を読みます。","romaji":"Shinbun o yomimasu.","th":"อ่านหนังสือพิมพ์"},{"jp":"新幹線で行きます。","romaji":"Shinkansen de ikimasu.","th":"ไปด้วยชินคันเซ็น"}]},{"char":"古","on":"コ","kun":"ふる(い)","romaji":"ko / furu(i)","meaning":"เก่า","examples":[{"jp":"古い本があります。","roma