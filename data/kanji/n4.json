าย"}]},{"char":"春","on":"シュン","kun":"はる","romaji":"shun / haru","meaning":"ฤดูใบไม้ผลิ","examples":[{"jp":"春が来た。","romaji":"Haru ga kita.","th":"ฤดูใบไม้ผลิมาแล้ว"},{"jp":"春休み。","romaji":"Haru yasumi.","th":"ปิดเทอมฤดูใบไม้ผลิ"},{"jp":"青春。","romaji":"Seishun.","th":"วัยหนุ่มสาว"}]},{"char":"夏","on":"カ","kun":"なつ","romaji":"ka / natsu","meaning":"ฤดูร้อน","examples":[{"jp":"夏は暑い。","romaji":"Natsu wa atsui.","th":"ฤดูร้อนร้อน"},{"jp":"夏休み。","romaji":"Natsu yasumi.","th":"ปิดเทอมฤดูร้อน"},{"jp":"夏祭り。","romaji":"Natsu matsuri.","th":"เทศกาลฤดูร้อน"}]},{"char":"冬","on":"トウ","kun":"ふゆ","romaji":"tou / fuyu","meaning":"ฤดูหนาว","examples":[{"jp":"冬は寒い。","romaji":"Fuyu wa samui.","th":"ฤดูหนาวหนาว"},{"jp":"冬休み。","romaji":"Fuyu yasumi.","th":"ปิดเทอมฤดูหนาว"},{"jp":"冬の朝。","romaji":"Fuyu no asa.","th":"เช้าฤดูหนาว"}]},{"char":"朝","on":"チョウ","kun":"あさ","romaji":"chou / asa","meaning":"เช้า","examples":[{"jp":"朝ご飯を食べる。","romaji":"Asagohan o taberu.","th":"กินข้าวเช้า"},{"jp":"毎朝走る。","romaji":"Maiasa hashiru.","th":"วิ่งทุกเช้า"},{"jp":"今朝。","romaji":"Kesa.","th":"เมื่อเช้า"}]},{"char":"昼","on":"チュウ","kun":"ひる","romaji":"chuu / hiru","meaning":"กลางวัน","examples":[{"jp":"昼ご飯。","romaji":"Hirugohan.","th":"ข้าวเที่ยง"},{"jp":"昼休み。","romaji":"Hiruyasumi.","th":"พักกลางวัน"},{"jp":"昼間。","romaji":"Hiruma.","th":"ช่วงกลางวัน"}]},{"char":"夜","on":"ヤ","kun":"よる","romaji":"ya / yoru","meaning":"กลางคืน","examples":[{"jp":"夜遅い。","romaji":"Yoru osoi.","th":"ดึกแล้ว"},{"jp":"今夜。","romaji":"Konya.","th":"คืนนี้"},{"jp":"夜中。","romaji":"Yonaka.","th":"ดึกมาก"}]},{"char":"午","on":"ゴ","kun":"—","romaji":"go","meaning":"เที่ยง","examples":[{"jp":"午前中。","romaji":"Gozenchuu.","th":"ช่วงเช้า"},{"jp":"午後三時。","romaji":"Gogo sanji.","th":"บ่ายสาม"},{"jp":"正午。","romaji":"Shougo.","th":"เที่ยงตรง"}]},{"char":"世","on":"セ","kun":"よ","romaji":"se / yo","meaning":"โลก, ยุค","examples":[{"jp":"世界。","romaji":"Sekai.","th":"โลก"},{"jp":"世話をする。","romaji":"Sewa o suru.","th":"ดูแล"},{"jp":"世の中。","romaji":"Yo no 